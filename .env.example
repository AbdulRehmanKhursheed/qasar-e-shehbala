# ─── Database ─────────────────────────────────────────────────────────────────
# Supabase — Singapore region (ap-southeast-1)
# App uses the pooled PgBouncer string (required for serverless / Vercel functions)
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Prisma migrate uses the direct (non-pooled) connection
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# ─── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://qasrshehbala.pk"

# ─── WhatsApp ─────────────────────────────────────────────────────────────────
# E.164 without '+': 923001234567
NEXT_PUBLIC_WHATSAPP_NUMBER="923001234567"
NEXT_PUBLIC_PHONE="+92 300 0000000"
NEXT_PUBLIC_EMAIL="info@qasrshehbala.pk"

# ─── Media (Cloudflare R2 + Cloudflare Images) ────────────────────────────────
# R2 credentials — used server-side only for presigned upload URLs
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_R2_ACCESS_KEY_ID=""
CLOUDFLARE_R2_SECRET_ACCESS_KEY=""
CLOUDFLARE_R2_BUCKET="qasr-media"
CLOUDFLARE_R2_ENDPOINT="https://[account-id].r2.cloudflarestorage.com"

# Public delivery URL for Cloudflare Images (used by the custom next/image loader)
NEXT_PUBLIC_CF_IMAGES_URL="https://imagedelivery.net/[account-hash]/[bucket-name]"

# ─── Analytics ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# ─── Error tracking ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
